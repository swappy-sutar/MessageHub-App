# MessageHub Backend Environment Configuration Template

PORT=3000

# MongoDB Database Connection String
MONGODB_URL="mongodb+srv://<username>:<password>@cluster0.mongodb.net/messagehub"

# JWT Secret Key for Authentication
JWT_SECRET_KEY="your_strong_jwt_secret_key_here"

# Cloudinary Storage Configuration
CLOUDINARY_FOLDER_NAME="chat-app"
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# AES Message Encryption Key
ENCRYPTION_KEY="your_strong_aes_encryption_key_here"

NODE_ENV="development"
