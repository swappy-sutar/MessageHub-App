# Root gitignore for MessageHub project

# Node & Dependency directories
node_modules/
dist/
build/
.cache/

# Environment variable files containing sensitive keys & secrets
.env
.env.*
!.env.example

# Temporary files & logs
tmp/
*.log
npm-debug.log*
yarn-debug.log*
.tempmediaStorage/

# OS System Files
.DS_Store
Thumbs.db
